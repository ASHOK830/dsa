#1614. Maximum Nesting Depth of the Parentheses

class Solution:
    def maxDepth(self, s: str) -> int:
        li=list(s)

        max_count=0
        count=0
        for i in range(len(li)):
            if li[i]=="(":
                count+=1
                max_count=max(max_count, count)# here i am finding the depth using count
            if li[i]==")":
                count-=1
                max_count=max(max_count, count)
        return max_count


