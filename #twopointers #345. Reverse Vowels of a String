#345. Reverse Vowels of a String
class Solution:
    def reverseVowels(self, s: str) -> str:
        s=list(s)
        ovel=["a", "e","i","o","u"]
        left=0
        right=len(s)-1
        while left <= right:
    
            if s[left].lower() in ovel:
                if s[right].lower() in ovel:
                    s[left],s[right]=s[right],s[left]
                    left+=1
                    right-=1
                else:
                    right-=1
            else:
                left+=1
    
        return "".join(s)  


