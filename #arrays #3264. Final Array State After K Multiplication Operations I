#3264. Final Array State After K Multiplication Operations I



class Solution:
    def getFinalState(self, nums: List[int], k: int, multiplier: int) -> List[int]:
        for i in range(k):
            ans=nums.index(min(nums))
            nums[ans]*=multiplier
        return nums


###test case###
Input: nums = [2,1,3,5,6], k = 5, multiplier = 2

Output: [8,4,6,5,6]
