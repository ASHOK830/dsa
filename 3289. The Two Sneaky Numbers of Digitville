#3289. The Two Sneaky Numbers of Digitville

class Solution:
    def getSneakyNumbers(self, nums: List[int]) -> List[int]:
        
        duplicates = set()

        for i in nums:
            if nums.count(i) > 1:
                duplicates.add(i)
        li=list(duplicates)
        return li


