class Solution:
    def getSneakyNumbers(self, nums: List[int]) -> List[int]:
        
        c=[]
        dup=[]
        for i in range(len(nums)):
            if nums[i] in c and  nums[i] not in dup:
                dup.append(nums[i])
            else:
                c.append(nums[i])
        li=list(dup)
        return dup
