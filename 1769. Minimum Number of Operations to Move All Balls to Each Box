



#1769. Minimum Number of Operations to Move All Balls to Each
class Solution:
    def minOperations(self, boxes: str) -> List[int]:
       
        list(boxes)
        li=[]


        for i in range(len(boxes)):
    
            ans=0
            for  j in range(len(boxes)):
            
                if boxes[j]=="1":
                    x=abs(i-j)
                    ans=ans+x
            li.append(ans)
        return li

