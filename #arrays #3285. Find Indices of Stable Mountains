#3285. Find Indices of Stable Mountains



class Solution:
    def stableMountains(self, height: List[int], threshold: int) -> List[int]:
        li=list()
        for i in range(1,len(height)):
            if height[i-1] > threshold:
                li.append(i)

        return li


#test case##
Input: height = [1,2,3,4,5], threshold = 2

Output: [3,4]
