#3162. Find the Number of Good Pairs I





class Solution:
    def numberOfPairs(self, nums1: List[int], nums2: List[int], k: int) -> int:
        count=0
       
        for  i in range(len(nums1)):
            for j in range(len(nums2)):
                if nums1[i]%nums2[j]==0:
                    print(nums1[i],nums2[j]*k)
                    count=count+1
        return count
            
