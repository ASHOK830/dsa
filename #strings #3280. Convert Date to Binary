#3280. Convert Date to Binary

class Solution:
    def convertDateToBinary(self, date: str) -> str:

        x = date.split("-")
        li = []
        for i in range(len(x)):
            li.append(format(int(x[i]), "b"))  
            result = "-".join(li)
        return result



