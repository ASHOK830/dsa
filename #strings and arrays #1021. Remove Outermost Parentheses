#1021. Remove Outermost Parentheses


class Solution:
    def removeOuterParentheses(self, s: str) -> str:

            
            ans=""
            count=0
            for i in s:
                if i=="(":
                    count+=1
                    if count > 1 :
                        ans+=i
                if i==")":
                    count-=1
                    if count >0 :
                        ans+=i
            
            return ans




