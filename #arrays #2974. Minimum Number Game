#2974. Minimum Number Game

class Solution:
    def numberGame(self, nums: List[int]) -> List[int]:

 
        li=[]
        nums.sort()
        n=len(nums)
        for i in range(0,n,2):
            a=nums[i]
            b=nums[i+1]
    
            li.append(b)
            li.append(a)
        return li

