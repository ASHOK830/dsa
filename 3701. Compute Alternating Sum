###3701. Compute Alternating Sum

class Solution:
    def alternatingSum(self, nums: List[int]) -> int:
        
        odd=0
        even=0
        n=len(nums)
        for i in range(n):
            if i%2==0:
                even=even+nums[i]
            else:
                odd=odd+nums[i]
        Alt_sum=even-odd
        return Alt_sum



