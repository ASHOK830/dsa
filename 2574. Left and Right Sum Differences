#2574. Left and Right Sum Differences

#using  prefix_sum concept:-


class Solution:
    def leftRightDifference(self, nums: List[int]) -> List[int]:


        leftsum=0
        total_sum=sum(nums)
        ans=[]

        for i in range(len(nums)):
            rightsum=total_sum-leftsum-nums[i]
            ans.append(abs(leftsum-rightsum))
            leftsum= leftsum+nums[i]
        return ans










#normal  bruitforce :-
class Solution:
    def leftRightDifference(self, nums: List[int]) -> List[int]:


        leftsum=[]
        rightsum=[]
        answer=[]

        n=len(nums)

        for i in range(n):
            if i==0:
                leftsum.append(0)
            else:
                leftsum.append(sum(nums[:i]))

        for j in range(n):
            if j==n-1:
                rightsum.append(0)
            else:
                rightsum.append(sum(nums[j+1:]))


        for  i in range(len(leftsum)):
            answer.append(abs(leftsum[i]-rightsum[i]))
        return answer
