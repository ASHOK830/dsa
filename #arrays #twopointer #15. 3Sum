#15. 3Sum
class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        

        nums.sort()
        n=len(nums)
        li=set()

        l2=[]
        for  i  in range(n):
            j=i+1
            k=n-1
            while j< k:
                sum=nums[i]+nums[j]+nums[k]
                if sum==0:
                    ans=nums[i],nums[j],nums[k]
                    li.add(ans)
                    j=j+1
                    k=k-1
            
                if sum < 0:
                    j=j+1
            
                if sum > 0:
                    k=k-1
        for x in li:
            l2.append(list(x))

        return l2


